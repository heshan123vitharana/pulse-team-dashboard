# Backend Server Port
PORT=8000

# Database Connections (Neon Serverless PostgreSQL)
# Pooled connection string (for querying)
DATABASE_URL="postgres://<user>:<password>@<endpoint>.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Direct connection string (for Prisma migrations)
DIRECT_URL="postgres://<user>:<password>@<endpoint>.neon.tech/neondb?sslmode=require"

# JWT Secret Key for Authentication
JWT_SECRET="YOUR_SUPER_SECRET_KEY_HERE"
